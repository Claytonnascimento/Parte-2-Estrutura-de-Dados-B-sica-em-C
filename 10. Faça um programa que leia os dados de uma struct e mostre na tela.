#include <stdio.h>

struct Pessoa {
    char nome[50];
    int idade;
};

int main() {
    struct Pessoa pessoa;

    scanf("%s", pessoa.nome);
    scanf("%d", &pessoa.idade);

    printf("Dados cadastrados:\n");
    printf("Nome: %s\n", pessoa.nome);
    printf("Idade: %d\n", pessoa.idade);

    return 0;
}
